      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=\"game-monitor-db\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "TimescaleDB logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 4,
      "options": {
        "barRadius": 0,
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "orientation": "auto",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": -45,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  DATE_TRUNC('day', session_start) AS day,\n  COUNT(*) AS sessions,\n  ROUND(AVG(activity_score)::numeric, 2) AS avg_activity_score\nFROM activity_sessions\nWHERE session_start >= NOW() - INTERVAL '30 days'\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Sessions per day (last 30 days)",
      "type": "barchart"
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  id,\n  game_name,\n  to_char(session_start, 'YYYY-MM-DD HH24:MI') AS started,\n  total_duration / 60 AS total_min,\n  active_duration / 60 AS active_min,\n  ROUND(activity_score::numeric * 100, 1) AS score_pct,\n  state\nFROM activity_sessions\nORDER BY session_start DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Recent sessions",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["game-monitor"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Game Activity Monitor",
  "uid": "game-monitor-main",
  "version": 1
